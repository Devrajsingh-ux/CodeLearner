# =============================================================================
# ZENTAX (CodeLearner) - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# =============================================================================
# REQUIRED: Appwrite Configuration
# =============================================================================
# Get these from your Appwrite Console -> Project Settings

# Appwrite API Endpoint (e.g., https://cloud.appwrite.io/v1)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1

# Appwrite Project ID
NEXT_PUBLIC_APPWRITE_PROJECT_ID=69aa826d003e711776fd

# Appwrite Server API Key (with full permissions)
# Generate in Appwrite Console -> API Keys
# Required permissions: databases, users, collections, documents
APPWRITE_API_KEY=standard_d0f9d0cb40a257bcb818b638bfb9bb3723df7ac59c5452729e6d6f5cfa07030770fa74cb5a0d191a79b1bf7e1390c99fc62140280c69317271b9c028518b6a6e33fd908134b02616d0af6e6c34501545b356044215138384e96efe1a4104d838e865dda10a97c681a64795db33662d886fccfb62f1d5e266bc0a4e7fedd835af

# Appwrite Database ID (default: zentax_db)
APPWRITE_DATABASE_ID=zentax_db

# =============================================================================
# REQUIRED: Authentication Security
# =============================================================================

# JWT Secret Key - MUST be at least 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET=

# =============================================================================
# OPTIONAL: Redis (for rate limiting and caching)
# =============================================================================

# Redis connection URL
# If not set, falls back to memory-based rate limiting (not recommended for production)
REDIS_URL=redis://localhost:6379

# Rate limiting mode: 'true' to fail open (allow requests) when Redis is down
# Default: 'false' (fail closed - deny requests when Redis is unavailable)
RATE_LIMIT_FAIL_OPEN=false

# Enable/disable rate limiting (default: true)
RATE_LIMIT_ENABLED=true

# =============================================================================
# OPTIONAL: Code Compilation (Judge0 API)
# =============================================================================

# Judge0 CE API URL - can use public instance or self-hosted
# Public: https://judge0-ce.p.rapidapi.com
# Self-hosted: http://your-judge0-instance:2358
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# Judge0 RapidAPI Key (if using public instance)
# Get from: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=

# =============================================================================
# OPTIONAL: Monitoring & Error Tracking
# =============================================================================

# Sentry DSN for error tracking
# Get from: https://sentry.io
SENTRY_DSN=

# =============================================================================
# OPTIONAL: Application Configuration
# =============================================================================

# Application URL (used for internal API calls and email links)
# In production, set to your actual domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# =============================================================================
# OPTIONAL: Email Configuration (for password reset, notifications)
# =============================================================================

# SMTP Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Skip environment validation during build (for CI/CD)
SKIP_ENV_VALIDATION=false

# Enable verbose logging
DEBUG=false
